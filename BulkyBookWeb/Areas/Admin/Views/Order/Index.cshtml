

<div class="container-fluid py-4">


    <div class="card border shadow-sm overflow-hidden">
        <div class="card-header text-white py-3 px-4 d-flex align-items-center justify-content-between" style="background: linear-gradient(to right, #065f46, #282828, #191414);">
            <div>
                <h5 class="mb-0 fw-bold"><i class="bi bi-grid me-2"></i>Orders</h5>
                <p class="mb-0 small" style="color: #1DB954;">Manage your Orders</p>
            </div>
        </div>
        <div class="table-responsive p-3">
            <table id="tblData" class="table-styled">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Total</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/orders.js" asp-append-version="true"></script>
}
