<div class="container">
    <div class="row justify-content-center mt-5 mb-5">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-sm border overflow-hidden">
                <div class="card-header text-white py-3 px-4 text-center" style="background: linear-gradient(to right, #065f46, #282828, #191414);">
                    <i class="bi bi-person-plus-fill display-4"></i>
                    <h4 class="fw-bold mt-2 mb-1">Create Account</h4>
                    <p class="mb-0 small" style="color: #1DB954;">Join us today</p>
                </div>

                <div class="card-body p-5">
                    <form>
                        <!-- TODO: Add validation summary for ModelOnly errors with class "text-danger mb-3" -->

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <!-- TODO: Add label, input and validation tag helper for Name property -->
                                <label>Name</label>
                                <input type="text" class="form-control" placeholder="John Doe" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <!-- TODO: Add label, input and validation tag helper for Email property -->
                                <label>Email</label>
                                <input type="email" class="form-control" placeholder="name@example.com" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <!-- TODO: Add label, input and validation tag helper for Password property -->
                                <label>Password</label>
                                <input type="password" class="form-control" placeholder="••••••••" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <!-- TODO: Add label, input and validation tag helper for ConfirmPassword property -->
                                <label>Confirm Password</label>
                                <input type="password" class="form-control" placeholder="••••••••" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <!-- TODO: Add label, input and validation tag helper for PhoneNumber property -->
                            <label>Phone Number</label>
                            <input type="text" class="form-control" placeholder="(123) 456-7890" />
                        </div>

                        <div class="mb-3">
                            <!-- TODO: Add label, input and validation tag helper for StreetAddress property -->
                            <label>Street Address</label>
                            <input type="text" class="form-control" placeholder="123 Main St" />
                        </div>

                        <div class="row">
                            <div class="col-md-5 mb-3">
                                <!-- TODO: Add label, input and validation tag helper for City property -->
                                <label>City</label>
                                <input type="text" class="form-control" placeholder="New York" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <!-- TODO: Add label, input and validation tag helper for State property -->
                                <label>State</label>
                                <input type="text" class="form-control" placeholder="NY" />
                            </div>

                            <div class="col-md-3 mb-3">
                                <!-- TODO: Add label, input and validation tag helper for PostalCode property -->
                                <label>Postal Code</label>
                                <input type="text" class="form-control" placeholder="10001" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-accent btn-lg w-100 mb-3">
                            <i class="bi bi-person-check me-2"></i>Register
                        </button>
                    </form>

                    <hr class="my-4" />

                    <div class="text-center">
                        <!-- TODO: Add Link -->
                        <p class="mb-0">Already have an account? <a href="#" class="fw-semibold text-decoration-none" style="color: #17A34A;">Log in</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
