<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border overflow-hidden">
                <div class="card-header text-white py-3 px-4 text-center" style="background: linear-gradient(to right, #065f46, #282828, #191414);">
                    <i class="bi bi-box-arrow-in-right display-4"></i>
                    <h4 class="fw-bold mt-2 mb-1">Welcome Back</h4>
                    <p class="mb-0 small" style="color: #1DB954;">Log in to your account</p>
                </div>

                <div class="card-body p-5">
                    <form>
                        <!-- TODO: Add validation summary for ModelOnly errors with class "text-danger mb-3" -->
                        <div class="mb-3">
                            <!-- TODO: Add label, input and validation tag helper for Email property -->
                            <label>Email</label>
                            <input type="email" class="form-control form-control-lg" placeholder="name@example.com" />
                        </div>

                        <div class="mb-3">
                            <!-- TODO: Add label, input and validation tag helper for Password property -->
                            <label>Password</label>
                            <input type="password" class="form-control form-control-lg" placeholder="Enter your password" />
                        </div>

                        <div class="form-check mb-3">
                            <!-- TODO: RememberMe  -->
                            <input type="checkbox" class="form-check-input" />
                            <label class="form-check-label">Remember me?</label>
                        </div>

                        <button type="submit" class="btn btn-accent btn-lg w-100 mb-3">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Log In
                        </button>

                        <div class="text-center">
                            <a href="#" class="text-decoration-none">Forgot your password?</a>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <div class="text-center">
                        <!-- TODO: Add Link -->
                        <p class="mb-0">Don't have an account? <a href="#" class="fw-semibold text-decoration-none" style="color: #17A34A;">Register now</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


